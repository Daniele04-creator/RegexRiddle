# PostgreSQL container used by Docker Compose.
POSTGRES_USER=regexriddle
POSTGRES_PASSWORD=password
POSTGRES_DB=regexriddle

# Local backend and E2E database connection.
DATABASE_URL=postgresql://regexriddle:password@127.0.0.1:55432/regexriddle

# Local backend runtime.
API_HOST=127.0.0.1
API_PORT=4000
AUTH_COOKIE_SECURE=false

# Local frontend runtime.
WEB_HOST=127.0.0.1
WEB_PORT=5173
API_ORIGIN=http://127.0.0.1:4000
