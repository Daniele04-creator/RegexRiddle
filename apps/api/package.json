{
  "name": "@regexriddle/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "pnpm --filter @regexriddle/shared build && tsx watch src/server.ts",
    "build": "pnpm --filter @regexriddle/shared build && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --filter @regexriddle/shared build && vitest run"
  },
  "dependencies": {
    "@regexriddle/shared": "workspace:*",
    "fastify": "5.8.5"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
