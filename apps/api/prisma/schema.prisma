generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ControlKind {
  POSITIVE
  NEGATIVE
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  username     String     @unique
  email        String     @unique
  passwordHash String
  displayName  String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  challenges   Challenge[]
  attempts     Attempt[]
  solutions    Solution[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid()) @db.Uuid
  sessionTokenHash String   @unique
  userId           String   @db.Uuid
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Challenge {
  id                    String             @id @default(uuid()) @db.Uuid
  authorId              String             @db.Uuid
  title                 String
  description           String
  difficulty            Difficulty
  secretPattern         String
  flags                 String             @default("")
  publicPositiveExample String
  publicNegativeExample String
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  author                User               @relation(fields: [authorId], references: [id], onDelete: Restrict)
  controls              ChallengeControl[]
  attempts              Attempt[]
  solutions             Solution[]

  @@index([authorId])
  @@index([difficulty])
  @@map("challenges")
}

model ChallengeControl {
  id          String      @id @default(uuid()) @db.Uuid
  challengeId String      @db.Uuid
  kind        ControlKind
  value       String
  createdAt   DateTime    @default(now())
  challenge   Challenge   @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, kind, value])
  @@index([challengeId, kind])
  @@map("challenge_controls")
}

model Attempt {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  challengeId     String    @db.Uuid
  proposedPattern String
  flags           String    @default("")
  positiveMatched Int
  positiveTotal   Int
  negativeMatched Int
  negativeTotal   Int
  isCorrect       Boolean   @default(false)
  attemptNumber   Int
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge       Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId, attemptNumber])
  @@index([challengeId])
  @@index([userId])
  @@map("attempts")
}

model Solution {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  challengeId  String    @db.Uuid
  attemptsUsed Int
  solvedAt     DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([challengeId])
  @@map("solutions")
}
