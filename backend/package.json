{
  "name": "@regexriddle/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "pnpm db:generate && pnpm --filter @regexriddle/shared build && tsx watch src/server.ts",
    "build": "pnpm --filter @regexriddle/shared build && pnpm db:generate && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "pnpm db:generate && prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@regexriddle/shared": "workspace:*",
    "argon2": "0.44.0",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "re2-wasm": "1.0.2"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "prisma": "7.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
