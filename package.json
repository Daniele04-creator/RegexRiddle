{
  "name": "regexriddle",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "dev:frontend": "pnpm --dir frontend dev",
    "dev:backend": "pnpm --dir backend dev",
    "dev:web": "pnpm dev:frontend",
    "dev:api": "pnpm dev:backend",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --filter @regexriddle/shared --filter @regexriddle/api --filter @regexriddle/web --if-present test",
    "build": "pnpm -r --if-present build",
    "e2e": "pnpm --dir e2e test",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm e2e",
    "db:generate": "pnpm --dir backend db:generate",
    "db:migrate": "pnpm --dir backend db:migrate",
    "db:seed": "pnpm --dir backend db:seed",
    "db:verify": "pnpm --dir backend db:verify"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "typescript-eslint": "8.62.0"
  }
}
